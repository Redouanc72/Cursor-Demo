<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Lunar Basecamp Admin</label>
    <description>
        Full administrative access to all Lunar Basecamp Outfitters custom objects.
        Grants Create, Read, Edit, Delete, View All, and Modify All on:
        Lunar_Explorer__c, Gear_Item__c, Expedition_Booking__c,
        Safety_Certification__c, and Expedition_Gear__c.
        Includes read/edit FLS for all 27 custom fields across those objects.
        Master-Detail fields on Expedition_Gear__c are excluded — access
        is controlled by their respective parent object permissions.
    </description>
    <hasActivationRequired>false</hasActivationRequired>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!--  TAB VISIBILITY                                         -->
    <!--  All 5 custom object tabs set to Visible               -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <tabVisibilities>
        <tab>Lunar_Explorer__c</tab>
        <visibility>Visible</visibility>
    </tabVisibilities>

    <tabVisibilities>
        <tab>Gear_Item__c</tab>
        <visibility>Visible</visibility>
    </tabVisibilities>

    <tabVisibilities>
        <tab>Expedition_Booking__c</tab>
        <visibility>Visible</visibility>
    </tabVisibilities>

    <tabVisibilities>
        <tab>Safety_Certification__c</tab>
        <visibility>Visible</visibility>
    </tabVisibilities>

    <tabVisibilities>
        <tab>Expedition_Gear__c</tab>
        <visibility>Visible</visibility>
    </tabVisibilities>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!--  OBJECT PERMISSIONS                                     -->
    <!--  Full CRUD + View All + Modify All on all 5 objects     -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <objectPermissions>
        <object>Lunar_Explorer__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>true</allowDelete>
        <viewAllRecords>true</viewAllRecords>
        <modifyAllRecords>true</modifyAllRecords>
    </objectPermissions>

    <objectPermissions>
        <object>Gear_Item__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>true</allowDelete>
        <viewAllRecords>true</viewAllRecords>
        <modifyAllRecords>true</modifyAllRecords>
    </objectPermissions>

    <objectPermissions>
        <object>Expedition_Booking__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>true</allowDelete>
        <viewAllRecords>true</viewAllRecords>
        <modifyAllRecords>true</modifyAllRecords>
    </objectPermissions>

    <objectPermissions>
        <object>Safety_Certification__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>true</allowDelete>
        <viewAllRecords>true</viewAllRecords>
        <modifyAllRecords>true</modifyAllRecords>
    </objectPermissions>

    <objectPermissions>
        <object>Expedition_Gear__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>true</allowDelete>
        <viewAllRecords>true</viewAllRecords>
        <modifyAllRecords>true</modifyAllRecords>
    </objectPermissions>

